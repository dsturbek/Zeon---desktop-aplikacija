<UserControl x:Class="Zeon.FoodPlan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Zeon"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0A0A0A">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" 
                Background="#0D0D0D" 
                CornerRadius="8" 
                Padding="20">

            <DataGrid x:Name="dgPlans" 
                      AutoGenerateColumns="False"
                      MouseDoubleClick="DgPlans_MouseDoubleClick"
                      Background="Transparent" 
                      Foreground="#FFFFFD"
                      BorderThickness="0" 
                      GridLinesVisibility="None" 
                      HeadersVisibility="Column"
                      CanUserAddRows="False" 
                      IsReadOnly="True"
                      SelectionMode="Single" 
                      SelectionUnit="FullRow"
                      FontSize="14"
                      RowHeight="50">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#7A7A7A"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,15"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#2A2A2A"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="#FF0000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#141414"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding id_food_plan}" Width="60"/>
                    <DataGridTextColumn Header="NAZIV PLANA" Binding="{Binding food_plan_name}" Width="2*"/>
                    <DataGridTextColumn Header="OPIS" Binding="{Binding food_plan_description}" Width="3*"/>
                    <DataGridTextColumn Header="POČETAK" Binding="{Binding date_start, StringFormat='dd.MM.yyyy'}" Width="120"/>
                    <DataGridTextColumn Header="KRAJ" Binding="{Binding date_end, StringFormat='dd.MM.yyyy'}" Width="120"/>
                    <DataGridTextColumn Header="KLIJENT" Binding="{Binding Client.name_surname}" Width="1.5*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

            <Button x:Name="btnNew" Content="+ Novi plan" Click="BtnNew_Click"
                    Width="140" Height="45" Background="#FF0000" Foreground="White" 
                    FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,12,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="btnEdit" Content="Uredi" Click="BtnEdit_Click"
                    Width="110" Height="45" Background="#1A1A1A" Foreground="#FFFFFD" 
                    FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,12,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#3A3A3A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="btnDelete" Content="Briši" Click="BtnDelete_Click"
                    Width="110" Height="45" Background="#1A1A1A" Foreground="#FF4444" 
                    FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#3A3A3A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>