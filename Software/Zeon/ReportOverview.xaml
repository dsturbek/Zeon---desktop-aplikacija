<UserControl x:Class="Zeon.ReportOverview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Zeon"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0A0A0A">
    <DockPanel Margin="40,10,40,40">

        <Border DockPanel.Dock="Top"
                Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Odaberi klijenta" FontSize="11" Foreground="#7A7A7A" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbClients" Width="200" Height="36"
                              FontSize="13" Background="#2A2A2A" Foreground="#000"
                              BorderBrush="#3A3A3A"
                              DisplayMemberPath="name_surname"/>
                </StackPanel>

                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Početni datum" FontSize="11" Foreground="#7A7A7A" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dtpFrom" Width="170" Height="36"
                                FontSize="13" Background="#2A2A2A" Foreground="#000"
                                BorderBrush="#3A3A3A"/>
                </StackPanel>

                <StackPanel Margin="0,0,25,0">
                    <TextBlock Text="Završni datum" FontSize="11" Foreground="#7A7A7A" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dtpTo" Width="170" Height="36"
                                FontSize="13" Background="#2A2A2A" Foreground="#000"
                                BorderBrush="#3A3A3A"/>
                </StackPanel>

                <Button x:Name="btnGenerate" Content="Generiraj izvještaj" Click="BtnGenerate_Click"
                        Height="36" Padding="20,0"
                        FontSize="13" FontWeight="Bold"
                        Background="#FF0000" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

            </StackPanel>
        </Border>

        <TextBlock x:Name="txtError" DockPanel.Dock="Top"
                   Foreground="#FF4444" FontSize="13"
                   Margin="0,0,0,15" Visibility="Collapsed"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="stackReport" Visibility="Collapsed">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">

                    <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            CornerRadius="8" Padding="20" Margin="0,0,12,0" Width="240">
                        <StackPanel>
                            <TextBlock Text="PROMJENA TEŽINE" FontSize="10" Foreground="#7A7A7A" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtWeightChange" FontSize="32" FontWeight="Bold" Foreground="#FF0000"/>
                            <TextBlock x:Name="txtWeightDetail" FontSize="11" Foreground="#7A7A7A" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            CornerRadius="8" Padding="20" Margin="0,0,12,0" Width="240">
                        <StackPanel>
                            <TextBlock Text="UKUPNI TRENIZI" FontSize="10" Foreground="#7A7A7A" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtTotalTrainings" FontSize="32" FontWeight="Bold" Foreground="#FF0000"/>
                            <TextBlock x:Name="txtTrainingDetail" FontSize="11" Foreground="#7A7A7A" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                            CornerRadius="8" Padding="20" Width="240">
                        <StackPanel>
                            <TextBlock Text="OSOBNI REKORDI" FontSize="10" Foreground="#7A7A7A" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtPersonalRecords" FontSize="32" FontWeight="Bold" Foreground="#FF0000"/>
                            <TextBlock x:Name="txtPRDetail" FontSize="11" Foreground="#7A7A7A" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                        CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Promjena težine" FontSize="15" FontWeight="Bold" Foreground="#FFFFFD" Margin="0,0,0,15"/>
                        <Canvas x:Name="canvasWeight" Height="220" Background="#0A0A0A"/>
                    </StackPanel>
                </Border>

                <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
                        CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Ostvarenje zadanih vježbi" FontSize="15" FontWeight="Bold" Foreground="#FFFFFD" Margin="0,0,20,15"/>
                            <Border Background="#44FF44" Width="20" Height="3" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Usješno odrađeno" FontSize="11" Foreground="#44FF44" VerticalAlignment="Center" Margin="0,0,20,0" HorizontalAlignment="Center"/>
                            <Border Background="#FF0000" Width="20" Height="3" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Neuspješno odrađeno" FontSize="11" Foreground="#FF0000" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Canvas x:Name="canvasPlanStvarno" Height="220" Background="#0A0A0A"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>


    </DockPanel>
</UserControl>
