<UserControl x:Class="Zeon.RecipeCreate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000" Background="#0A0A0A">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0000"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                <Button x:Name="btnBack" Content="←" Style="{StaticResource DarkButton}" 
                        Width="40" Height="40" FontSize="18" Click="BtnCancel_Click" Margin="0,0,20,0"/>
                <TextBlock x:Name="txtHeader" Text="Novi Recept" FontSize="28" FontWeight="Bold" Foreground="#FFFFFD" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#121212" CornerRadius="8" Padding="20" BorderBrush="#222222" BorderThickness="1" Margin="0,0,20,0" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="NAZIV RECEPTA" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtRecipeName" Style="{StaticResource InputField}" Height="40" Margin="0,0,0,20"/>

                        <TextBlock Text="OPIS" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtDescription" Style="{StaticResource InputField}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"/>

                        <TextBlock Text="UPUTE ZA PRIPREMU" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtInstructions" Style="{StaticResource InputField}" Height="200" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#121212" CornerRadius="8" Padding="25" BorderBrush="#222222" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="DODAVANJE NAMIRNICA" Style="{StaticResource FieldLabel}" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Grid Grid.Row="1" Margin="0,0,0,20">
                            <TextBox x:Name="txtSearchFood" Style="{StaticResource InputField}" Height="40" Tag="Pretraži namirnice..." TextChanged="TxtSearchFood_TextChanged"/>
                        </Grid>

                        <Popup x:Name="popResults" IsOpen="False" PlacementTarget="{Binding ElementName=txtSearchFood}" StaysOpen="False">
                            <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1" Width="{Binding ElementName=txtSearchFood, Path=ActualWidth}">
                                <ListBox x:Name="lbFoodResults" Background="Transparent" BorderThickness="0" MaxHeight="250" 
                                         Foreground="White" MouseDoubleClick="LbFoodResults_MouseDoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding name}" Foreground="White" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding kCal, StringFormat='\{0\} kcal / 100g'}" Foreground="#9A9A9A" FontSize="12"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>

                        <DataGrid x:Name="dgIngredients" Grid.Row="2" AutoGenerateColumns="False" MinHeight="300"
                                  Background="#141414" Foreground="White" BorderThickness="0" 
                                  CanUserAddRows="False" RowHeight="50" 
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#222222"
                                  HeadersVisibility="Column" SelectionMode="Single"
                                  CellEditEnding="DgIngredients_CellEditEnding">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#141414"/>
                                    <Setter Property="Foreground" Value="#7A7A7A"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,0,10,10"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#222222"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#141414"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#222222"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                <Border Padding="10,0" Background="{TemplateBinding Background}" BorderThickness="0">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NAMIRNICA" Binding="{Binding Food.name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="KOLIČINA (g)" Binding="{Binding amount_grams, UpdateSourceTrigger=PropertyChanged}" Width="120"/>

                                <DataGridTemplateColumn Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Ukloni" 
                            Click="BtnRemoveIngredient_Click"
                            Foreground="#FF4444" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            HorizontalAlignment="Right"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Grid.Row="3" x:Name="lblTotalKcal" Text="Ukupno: 0 kcal" Foreground="#FF0000" 
                                   FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,20,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="Odustani" Style="{StaticResource DarkButton}" Width="120" Height="45" Margin="0,0,15,0" Click="BtnCancel_Click" Focusable="False"/>
                <Button x:Name="btnSave" Content="SPREMI RECEPT" Style="{StaticResource RedButton}" Width="180" Height="45" Click="BtnSave_Click" Focusable="False"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>