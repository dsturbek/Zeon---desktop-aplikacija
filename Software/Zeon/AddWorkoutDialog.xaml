<Window x:Class="Zeon.AddWorkoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj trening"
        Height="420" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#141414">

    <StackPanel Margin="25">
        <!--Odabir-->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <RadioButton x:Name="rbExisting"
                         Content="Postojeći trening"
                         Foreground="#FFFFFD"
                         FontSize="14"
                         Margin="0,0,20,0"
                         IsChecked="True"
                         Checked="rbMode_Checked"/>
            <RadioButton x:Name="rbNew"
                         Content="Novi trening"
                         Foreground="#FFFFFD"
                         FontSize="14"
                         Checked="rbMode_Checked"/>
        </StackPanel>

        <!--Postojeći treininzi-->
        <StackPanel x:Name="panelExisting">
            <TextBlock Text="Odaberi trening"
                       FontSize="13"
                       Foreground="#9A9A9A"
                       Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbExistingWorkouts"
                      Background="#1A1A1A"
                      Foreground="#212121"
                      BorderBrush="#2A2A2A"
                      BorderThickness="1"
                      Padding="12,10"
                      FontSize="14"
                      DisplayMemberPath="workout_name"/>
        </StackPanel>

        <!--Definiranje novog treninga-->
        <StackPanel x:Name="panelNew" Visibility="Collapsed">
            <TextBlock Text="Naziv treninga"
                       FontSize="13"
                       Foreground="#9A9A9A"
                       Margin="0,0,0,5"/>
            <TextBox x:Name="txtWorkoutName"
                     Background="#1A1A1A"
                     Foreground="#FFFFFD"
                     BorderBrush="#2A2A2A"
                     BorderThickness="1"
                     Padding="12,10"
                     FontSize="14"
                     CaretBrush="#FFFFFD"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Mišićna skupina"
                       FontSize="13"
                       Foreground="#9A9A9A"
                       Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbMuscleGroup"
                      Background="#1A1A1A"
                      Foreground="#212121"
                      BorderBrush="#2A2A2A"
                      BorderThickness="1"
                      Padding="12,10"
                      FontSize="14"
                      IsEditable="False">
                <ComboBoxItem Content="Prsa"/>
                <ComboBoxItem Content="Leđa"/>
                <ComboBoxItem Content="Ramena"/>
                <ComboBoxItem Content="Biceps"/>
                <ComboBoxItem Content="Triceps"/>
                <ComboBoxItem Content="Noge"/>
                <ComboBoxItem Content="Trbušnjaci"/>
                <ComboBoxItem Content="Cijelo tijelo"/>
                <ComboBoxItem Content="Kardio"/>
            </ComboBox>
        </StackPanel>

        <TextBlock Text="Dan programa"
                   FontSize="13"
                   Foreground="#9A9A9A"
                   Margin="0,15,0,5"/>
        <TextBox x:Name="txtDay"
                 Background="#1A1A1A"
                 Foreground="#FFFFFD"
                 BorderBrush="#2A2A2A"
                 BorderThickness="1"
                 Padding="12,10"
                 FontSize="14"
                 CaretBrush="#FFFFFD"
                 Width="80"
                 HorizontalAlignment="Left"
                 Text="1"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button Content="Odustani"
                    Background="#2A2A2A"
                    Foreground="#9A9A9A"
                    BorderThickness="0"
                    Padding="20,12"
                    FontSize="14"
                    Cursor="Hand"
                    Margin="0,0,10,0"
                    Click="btnDialogCancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Dodaj"
                    Background="#FF0000"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="20,12"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Click="btnDialogOk_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
