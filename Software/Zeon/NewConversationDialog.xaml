<Window x:Class="Zeon.NewConversationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova poruka"
        Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#141414">

    <StackPanel Margin="25">
        <TextBlock Text="Odaberite klijenta"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#FFFFFD"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Pretraga"
                   FontSize="13"
                   Foreground="#9A9A9A"
                   Margin="0,0,0,5"/>
        <TextBox x:Name="txtSearch"
                 Background="#1A1A1A"
                 Foreground="#FFFFFD"
                 BorderBrush="#2A2A2A"
                 BorderThickness="1"
                 Padding="12,10"
                 FontSize="14"
                 CaretBrush="#FFFFFD"
                 Margin="0,0,0,15"
                 TextChanged="txtSearch_TextChanged"/>

        <ListBox x:Name="lstClients"
                 Background="#1A1A1A"
                 Foreground="#FFFFFD"
                 BorderBrush="#2A2A2A"
                 BorderThickness="1"
                 Height="230"
                 FontSize="14"
                 DisplayMemberPath="name_surname"
                 SelectionChanged="lstClients_SelectionChanged"/>
    </StackPanel>
</Window>
