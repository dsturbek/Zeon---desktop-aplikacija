<UserControl x:Class="Zeon.FeedbackOverview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Zeon"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0A0A0A">

    <DockPanel Margin="40">

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">

            <Label Content="Filter:" Foreground="#7A7A7A" FontSize="14" Margin="0,0,10,0"/>

            <RadioButton x:Name="rbAll" Content="Svi" GroupName="FeedbackFilter" 
                         IsChecked="True" Margin="10,0" Checked="FilterChanged"
                         FontSize="14" Foreground="#fff"/>

            <RadioButton x:Name="rbTraining" Content="Treninzi" GroupName="FeedbackFilter" 
                         Margin="10,0" Checked="FilterChanged"
                         FontSize="14" Foreground="#fff"/>

            <RadioButton x:Name="rbMeal" Content="Obroci" GroupName="FeedbackFilter" 
                         Margin="10,0" Checked="FilterChanged"
                         FontSize="14" Foreground="#fff"/>

            <Label Content="Klijent:" Foreground="#7A7A7A" FontSize="14" Margin="30,0,5,0"/>

            <ComboBox x:Name="cmbClients" Width="200" Margin="5,0"
                      FontSize="14"
                      Background="#2A2A2A"
                      Foreground="#000"
                      BorderBrush="#3A3A3A"
                      DisplayMemberPath="name_surname" 
                      SelectionChanged="CmbClients_SelectionChanged"/>

            <Button Content="Resetiraj" Click="BtnReset_Click" 
                    Margin="20,0,0,0" 
                    Padding="15,8"
                    FontSize="14"
                    Background="#2A2A2A"
                    Foreground="#FFFFFD"
                    BorderBrush="#3A3A3A"
                    Cursor="Hand"/>

        </StackPanel>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="stackKartice" Margin="0,10,0,0"/>
        </ScrollViewer>
        
    </DockPanel>
</UserControl>
