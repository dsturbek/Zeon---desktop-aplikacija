<UserControl x:Class="PresentationLayer.Windows.FrmAddClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#0A0A0A">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="2"
                Background="#1A1A1A"
                CornerRadius="8"
                Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Pretraga (ime/username/email):"
                           VerticalAlignment="Center"
                           Foreground="#FFFFFD"
                           FontSize="14"
                           Margin="0,0,15,0"/>
                <TextBox x:Name="txtSearchAll"
                         Width="400"
                         Height="40"
                         Padding="15,0"
                         FontSize="14"
                         Background="#2A2A2A"
                         Foreground="#FFFFFD"
                         BorderBrush="#3A3A3A"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         TextChanged="txtSearchAll_TextChanged"/>
                <Button Content="Osvjezi"
                        Width="120"
                        Height="40"
                        Margin="15,0,0,0"
                        FontSize="14"
                        Background="#2A2A2A"
                        Foreground="#FFFFFD"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnRefresh_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Background="#1A1A1A"
                CornerRadius="8"
                Padding="5">
            <DataGrid x:Name="dgAllClients"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Background="#1A1A1A"
                      Foreground="#FFFFFD"
                      BorderThickness="0"
                      RowBackground="#1A1A1A"
                      AlternatingRowBackground="#222222"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      FontSize="14">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2A2A2A"/>
                        <Setter Property="Foreground" Value="#7A7A7A"/>
                        <Setter Property="Padding" Value="15,12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF0000"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF0000"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding id_client}" Width="80"/>
                    <DataGridTextColumn Header="Ime i prezime" Binding="{Binding name_surname}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="250"/>
                    <DataGridTextColumn Header="Username" Binding="{Binding username}" Width="150"/>
                    <DataGridTextColumn Header="Trener ID" Binding="{Binding TrainerId}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Dodaj"
                    Width="130"
                    Height="45"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#FF0000"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnAssign_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
