<UserControl x:Class="PresentationLayer.Windows.FrmClients"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Klijenti"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="#FFFFFD"
                   Margin="0,0,0,20"/>

    <TabControl x:Name="tabClients"
                Grid.Row="1"
                Background="Transparent"
                BorderThickness="0"
                SelectionChanged="tabClients_SelectionChanged">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Foreground" Value="#7A7A7A"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Padding" Value="15,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="tabBorder"
                                    Background="Transparent"
                                    BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="0,0,10,0"
                                    Cursor="Hand">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="tabBorder" Property="BorderBrush" Value="#FF0000"/>
                                    <Setter Property="Foreground" Value="#FFFFFD"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>

        <!-- Popis klijenata -->
        <TabItem Header="Moji klijenti">
            <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="2"
                        Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Pretraga (ime):"
                                   VerticalAlignment="Center"
                                   Foreground="#FFFFFD"
                                   FontSize="14"
                                   Margin="0,0,15,0"/>
                        <TextBox x:Name="txtSearchName"
                                 Width="350"
                                 Height="40"
                                 Padding="15,0"
                                 FontSize="14"
                                 Background="#2A2A2A"
                                 Foreground="#FFFFFD"
                                 BorderBrush="#3A3A3A"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 TextChanged="txtSearchName_TextChanged"/>
                        <Button Content="Resetiraj"
                                Width="120"
                                Height="40"
                                Margin="15,0,0,0"
                                FontSize="14"
                                Background="#2A2A2A"
                                Foreground="#FFFFFD"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnRefresh_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A3A3A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="5">
                    <DataGrid x:Name="dgClients"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              Background="#1A1A1A"
                              Foreground="#FFFFFD"
                              BorderThickness="0"
                              RowBackground="#1A1A1A"
                              AlternatingRowBackground="#222222"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              FontSize="14">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                                <Setter Property="Padding" Value="15,12"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="15,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF0000"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF0000"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding id_client}" Width="80"/>
                            <DataGridTextColumn Header="Ime i prezime" Binding="{Binding name_surname}" Width="*"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding email}" Width="250"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding username}" Width="150"/>
                            <DataGridTextColumn Header="Registracija" Binding="{Binding registration_date, StringFormat=\{0:dd.MM.yyyy\}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Detalji"
                            Width="130"
                            Height="45"
                            Margin="0,0,10,0"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#2A2A2A"
                            Foreground="#FFFFFD"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnDetails_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Obrisi"
                            Width="130"
                            Height="45"
                            Margin="0,0,10,0"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#2A2A2A"
                            Foreground="#FFFFFD"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnRemove_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Dodaj"
                            Width="130"
                            Height="45"
                            FontSize="14"
                            FontWeight="Bold"
                            Background="#FF0000"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnAdd_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CC0000"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </TabItem>

        <!--Dodaj klijenta -->
        <TabItem Header="Dodaj klijenta" x:Name="tabAddClient">
            <ContentControl x:Name="addClientContent"/>
        </TabItem>
    </TabControl>
    </Grid>
</UserControl>
