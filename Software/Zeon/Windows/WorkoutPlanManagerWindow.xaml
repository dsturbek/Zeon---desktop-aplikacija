<UserControl x:Class="PresentationLayer.Windows.WorkoutPlanManagerWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0A0A"
             Loaded="UserControl_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Upravljanje planom treninga"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#FFFFFD"/>

        <Border Grid.Row="2"
                Background="#1A1A1A"
                CornerRadius="8"
                Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Naziv plana:"
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPlanName"
                             Height="40"
                             Padding="15,0"
                             FontSize="14"
                             Background="#2A2A2A"
                             Foreground="#FFFFFD"
                             BorderBrush="#3A3A3A"
                             BorderThickness="1"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Datum pocetka:"
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpStartDate"
                                Height="40"
                                FontSize="14"
                                Background="#2A2A2A"
                                Foreground="#2A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Datum zavrsetka:"
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpEndDate"
                                Height="40"
                                FontSize="14"
                                Background="#2A2A2A"
                                Foreground="#2A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#1A1A1A"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="TRENINZI PO DANIMA"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#7A7A7A"/>

                    <ListBox x:Name="lbWorkouts"
                             Grid.Row="2"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="lbWorkouts_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2A2A2A"
                                        CornerRadius="5"
                                        Padding="15"
                                        Margin="0,0,0,5"
                                        Width="290">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DayLabel}"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="#FF0000"/>
                                            <TextBlock Text="{Binding WorkoutName}"
                                                       FontSize="14"
                                                       Foreground="#FFFFFD"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="X"
                                                Width="25"
                                                Height="25"
                                                Background="#3A3A3A"
                                                Foreground="#FF0000"
                                                BorderThickness="0"
                                                FontWeight="Bold"
                                                Cursor="Hand"
                                                Tag="{Binding}"
                                                Click="btnRemoveWorkout_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="4"
                            Background="#2A2A2A"
                            CornerRadius="5"
                            Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Dodaj trening (broj označava dan)"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#7A7A7A"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="txtDay"
                                         Grid.Column="0"
                                         Height="35"
                                         Padding="10,0"
                                         FontSize="14"
                                         Background="#1A1A1A"
                                         Foreground="#FFFFFD"
                                         BorderBrush="#3A3A3A"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         Text="1"/>

                                <ComboBox x:Name="cmbWorkouts"
                                          Grid.Column="2"
                                          Height="35"
                                          FontSize="14"
                                          Background="#2A2A2A"
                                          BorderBrush="#3A3A3A"
                                          DisplayMemberPath="workout_name"/>
                            </Grid>

                            <Button Grid.Row="4"
                                    Content="Dodaj"
                                    Height="35"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Background="#FF0000"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnAddWorkout_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="5">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#CC0000"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#1A1A1A"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="VJEZBE U TRENINGU"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtSelectedWorkout"
                                   Text=""
                                   FontSize="14"
                                   Foreground="#FFFFFD"
                                   Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid x:Name="dgExercises"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              Background="#1A1A1A"
                              Foreground="#FFFFFD"
                              BorderThickness="0"
                              RowBackground="#1A1A1A"
                              AlternatingRowBackground="#222222"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              FontSize="14"
                              CanUserAddRows="False"
                              CellEditEnding="dgExercises_CellEditEnding">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                                <Setter Property="Padding" Value="15,10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="15,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3A3A3A"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Vjezba" Binding="{Binding ExerciseName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Serije" Binding="{Binding Sets, Mode=TwoWay}" Width="80"/>
                            <DataGridTextColumn Header="Ponavljanja" Binding="{Binding Reps, Mode=TwoWay}" Width="100"/>
                            <DataGridTextColumn Header="Tezina (kg)" Binding="{Binding Weight, Mode=TwoWay}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="4"
                            Background="#2A2A2A"
                            CornerRadius="5"
                            Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="cmbExercises"
                                      Grid.Column="0"
                                      Height="35"
                                      FontSize="14"
                                      Background="#2A2A2A"
                                      BorderBrush="#3A3A3A"
                                      DisplayMemberPath="exercise_name"/>

                            <Button Grid.Column="1"
                                    Content="Dodaj vjezbu"
                                    Height="35"
                                    Padding="20,0"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Background="#FF0000"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="btnAddExercise_Click" Grid.ColumnSpan="2" Margin="10,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="5"
                                                            Padding="5,5">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#CC0000"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Obrisi plan"
                    Width="130"
                    Height="45"
                    Margin="0,0,10,0"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#3A3A3A"
                    Foreground="#FF6666"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnDeletePlan_Click"
                    x:Name="btnDeletePlan">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Natrag"
                    Width="130"
                    Height="45"
                    Margin="0,0,10,0"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#2A2A2A"
                    Foreground="#FFFFFD"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnBack_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Spremi"
                    Width="130"
                    Height="45"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#FF0000"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnSave_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
