<UserControl x:Class="PresentationLayer.Windows.ClientDetailsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#0A0A0A"
             Loaded="UserControl_Loaded">

    <Grid Margin="30,30,30,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A1A1A"
                CornerRadius="8"
                Padding="15,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="KLIJENT"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#7A7A7A"
                               Margin="0,0,0,3"/>
                    <TextBlock x:Name="txtClientName"
                               Text="Ime klijenta"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#FFFFFD"/>
                </StackPanel>
                <TextBlock x:Name="txtClientEmail"
                           Text="email@example.com"
                           FontSize="13"
                           Foreground="#7A7A7A"
                           Margin="30,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#1A1A1A"
                CornerRadius="8"
                Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="TRENUTNI CILJ"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#7A7A7A"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnSetGoal"
                            Content="Postavi novi cilj"
                            Margin="20,0,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Background="#FF0000"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnSetGoal_Click" Height="30">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5"
                                                    Padding="5,5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CC0000"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Border x:Name="pnlGoalExists"
                        Grid.Row="2"
                        Background="#2A2A2A"
                        CornerRadius="5"
                        Padding="20"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="txtGoalName"
                                       Text="-"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFD"/>
                            <TextBlock x:Name="txtGoalDescription"
                                       Text="-"
                                       FontSize="13"
                                       Foreground="#9A9A9A"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Kalorije"
                                       FontSize="11"
                                       Foreground="#7A7A7A"/>
                            <TextBlock x:Name="txtGoalCalories"
                                       Text="- kcal"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#00FF00"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" VerticalAlignment="Center">
                            <TextBlock Text="Voda"
                                       FontSize="11"
                                       Foreground="#7A7A7A"/>
                            <TextBlock x:Name="txtGoalWater"
                                       Text="- L"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#00BFFF"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="pnlNoGoal"
                        Grid.Row="2"
                        Background="#2A2A2A"
                        CornerRadius="5"
                        Padding="20"
                        Visibility="Visible">
                    <TextBlock Text="Klijent nema postavljeni cilj."
                               FontSize="14"
                               Foreground="#7A7A7A"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="#1A1A1A"
                CornerRadius="8"
                Padding="25" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="PLAN TRENINGA"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#7A7A7A"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnImportTemplate"
                            Content="Uvezi iz predloška"
                            Margin="20,0,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Background="#2A2A2A"
                            Foreground="#FFFFFD"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnImportTemplate_Click" Height="31">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5"
                                                    Padding="5,5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3A3A3A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnManagePlan"
                            Content="Upravljaj planom"
                            Margin="20,0,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Background="#FF0000"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnManagePlan_Click" Height="31">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5"
                                                    Padding="5,5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CC0000"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Border x:Name="pnlPlanExists"
                        Grid.Row="2"
                        Background="#2A2A2A"
                        CornerRadius="5"
                        Padding="20"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock x:Name="txtPlanName"
                                       Text="Naziv plana"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFFD"/>
                            <TextBlock x:Name="txtPlanDates"
                                       Text="01.01.2025 - 01.02.2025"
                                       FontSize="13"
                                       Foreground="#9A9A9A"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                            <ItemsControl x:Name="icWorkouts">
                                <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A1A1A"
                                            CornerRadius="5"
                                            Padding="15"
                                            Margin="0,0,0,10">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DayLabel}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="#FF0000"
                                                           Width="60"/>
                                                <TextBlock Text="{Binding WorkoutName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFFFD"/>
                                                <TextBlock Text="{Binding MuscleGroup}"
                                                           FontSize="12"
                                                           Foreground="#7A7A7A"
                                                           Margin="15,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ExercisesSummary}"
                                                       FontSize="12"
                                                       Foreground="#9A9A9A"
                                                       Margin="60,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border x:Name="pnlNoPlan"
                        Grid.Row="2"
                        Background="#2A2A2A"
                        CornerRadius="5"
                        Padding="20"
                        Visibility="Visible">
                    <TextBlock Text="Klijent nema postavljeni plan treninga."
                               FontSize="14"
                               Foreground="#7A7A7A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Button Grid.Row="6"
                Content="Natrag"
                Height="45"
                FontSize="14"
                FontWeight="Bold"
                Background="#2A2A2A"
                Foreground="#FFFFFD"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Right"
                Width="150"
                Click="btnBack_Click" Margin="0,10,0,-10">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3A3A3A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</UserControl>
