<Window x:Name="GoalsWindow" x:Class="Zeon.SettingGoalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zeon"
        mc:Ignorable="d"
        Height="800" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Postavljanje ciljeva klijentu" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Foreground="#FFFFFD"/>

        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="INFORMACIJE O KLIJENTU" 
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   Margin="0,0,0,20"/>


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="Visina (cm):" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtHeight"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#FFFFFD"
                                         BorderBrush="#3A3A3A"
                                         BorderThickness="1"
                                         IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <Label Content="Težina (kg):" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtWeight"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#FFFFFD"
                                         BorderBrush="#3A3A3A"
                                         BorderThickness="1"
                                         IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <Label Content="Spol:" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtGender"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#FFFFFD"
                                         BorderBrush="#3A3A3A"
                                         BorderThickness="1"
                                         IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <Label Content="Godine:" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtAge"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#FFFFFD"
                                         BorderBrush="#3A3A3A"
                                         BorderThickness="1"
                                         IsReadOnly="True"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="RAZINA AKTIVNOSTI" 
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   Margin="0,0,0,20"/>

                        <Label Content="Odaberite razinu aktivnosti klijenta:" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <ComboBox Name="cmbActivityLevel" 
                                  Height="45"
                                  FontSize="14"
                                  Background="#2A2A2A"
                                  Foreground="#212121"
                                  BorderBrush="#3A3A3A"
                                  Padding="15,0">
                            <ComboBoxItem Content="Sjedilački (bez vježbanja)" IsSelected="True"/>
                            <ComboBoxItem Content="Lagana aktivnost (1-3 dana/tjedan)"/>
                            <ComboBoxItem Content="Umjerena aktivnost (3-5 dana/tjedan)"/>
                            <ComboBoxItem Content="Intenzivna aktivnost (6-7 dana/tjedan)"/>
                            <ComboBoxItem Content="Ekstremna aktivnost (2x dnevno)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="VRSTA CILJA" 
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   Margin="0,0,0,20"/>

                        <Label Content="Odaberite željeni cilj (kilaža):" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <ComboBox Name="cmbOdabirCilja" 
                                  Height="45"
                                  FontSize="14"
                                  Background="#2A2A2A"
                                  Foreground="#212121"
                                  BorderBrush="#3A3A3A"
                                  Padding="15,0">
                            <ComboBoxItem Content="Gubiti težinu" IsSelected="True"/>
                            <ComboBoxItem Content="Dobiti na težini"/>
                            <ComboBoxItem Content="Graditi mišiće"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Button Name="btnCalulate"
                        Content="Izračunaj"
                        Height="50"
                        FontSize="15"
                        FontWeight="Bold"
                        Background="#FF0000"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnCalulate_Click"
                        Margin="0,0,0,20">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#CC0000"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Border Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="KALKULACIJE" 
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   Margin="0,0,0,20"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="BMR (Bazalni metabolizam):" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtBMR"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#00FF00"
                                         FontWeight="Bold"
                                         BorderBrush="#3A3A3A"
                                         BorderThickness="1"
                                         IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="TDEE (Ukupan dnevni utrošak):" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtTDEE"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#00FF00"
                                         FontWeight="Bold"
                                         BorderBrush="#3A3A3A"
                                         BorderThickness="1"
                                         IsReadOnly="True"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="POSTAVLJANJE CILJEVA" 
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   Margin="0,0,0,20"/>

                        <Label Content="Naziv cilja:" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <TextBox Name="txtGoalName"
                                 Height="40"
                                 Padding="15,0"
                                 FontSize="14"
                                 Background="#2A2A2A"
                                 Foreground="#FFFFFD"
                                 BorderBrush="#3A3A3A"
                                 BorderThickness="1"
                                 Margin="0,0,0,15"/>

                        <Label Content="Opis cilja:" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <TextBox Name="txtGoalDescription"
                                 Height="80"
                                 Padding="15,10"
                                 FontSize="14"
                                 Background="#2A2A2A"
                                 Foreground="#FFFFFD"
                                 BorderBrush="#3A3A3A"
                                 BorderThickness="1"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="Ciljani kalorijski unos (kcal):" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtTargetCalories"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#FFFFFD"
                                         BorderThickness="2"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="Dnevna količina vode (L):" 
                                       Foreground="#FFFFFD"
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                                <TextBox Name="txtGoalWater"
                                         Height="40"
                                         Padding="15,0"
                                         FontSize="14"
                                         Background="#2A2A2A"
                                         Foreground="#FFFFFD"
                                         BorderThickness="2"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="💡 Ciljani unos kalorija i vode su automatski izračunati na temelju TDEE, ali ih možete ručno prilagoditi."
                                   FontSize="12"
                                   Foreground="#7A7A7A"
                                   TextWrapping="Wrap"
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Name="btnCancel"
                    Content="Odustani"
                    Height="50"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="#2A2A2A"
                    Foreground="#FFFFFD"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnCancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    Name="btnSave"
                    Content="Spremi ciljeve"
                    Height="50"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="#FF0000"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnSave_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
