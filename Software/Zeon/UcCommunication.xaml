<UserControl x:Class="Zeon.UcCommunication"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0A0A0A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Zaglavlje -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Komunikacija"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#FFFFFD"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Tabovi -->
        <TabControl x:Name="tabCommunication"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#7A7A7A"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="Padding" Value="15,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="tabBorder"
                                        Background="Transparent"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="0,0,10,0"
                                        Cursor="Hand">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder" Property="BorderBrush" Value="#FF0000"/>
                                        <Setter Property="Foreground" Value="#FFFFFD"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Razgovori -->
            <TabItem Header="Chat">
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Popis razgovora -->
                    <Border Grid.Column="0"
                            Background="#0D0D0D"
                            CornerRadius="8,0,0,8">
                        <DockPanel>
                            <Button x:Name="btnNewConversation"
                                    DockPanel.Dock="Bottom"
                                    Content="+ Nova poruka"
                                    Background="#FF0000"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="12,10"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    HorizontalAlignment="Right"
                                    Margin="10,10,10,10"
                                    Click="btnNewConversation_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#CC0000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBox x:Name="txtSearchConversations"
                                     DockPanel.Dock="Top"
                                     Background="#1A1A1A"
                                     Foreground="#FFFFFD"
                                     BorderBrush="#2A2A2A"
                                     BorderThickness="0,0,0,1"
                                     Padding="15,12"
                                     FontSize="13"
                                     CaretBrush="#FFFFFD"
                                     Tag="Pretraži razgovore..."
                                     TextChanged="txtSearchConversations_TextChanged"/>

                            <TextBlock x:Name="txtNoConversations"
                                       Text="Nema razgovora"
                                       FontSize="14"
                                       Foreground="#7A7A7A"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,0"
                                       Visibility="Collapsed"/>

                            <ListBox x:Name="lstConversations"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     SelectionChanged="lstConversations_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="15,12"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="itemBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderThickness="3,0,0,0"
                                                            BorderBrush="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="itemBorder" Property="Background" Value="#1A1A1A"/>
                                                            <Setter TargetName="itemBorder" Property="BorderBrush" Value="#FF0000"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="itemBorder" Property="Background" Value="#141414"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="{Binding ClientName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFFFFD"/>
                                                <TextBlock Text="{Binding MessageCount}"
                                                           FontSize="11"
                                                           Foreground="#7A7A7A"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <TextBlock Text="{Binding LastMessage}"
                                                       FontSize="12"
                                                       Foreground="#7A7A7A"
                                                       Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="230"
                                                       HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#2A2A2A"/>

                    <!-- Razgovor -->
                    <Border Grid.Column="2"
                            Background="#0D0D0D"
                            CornerRadius="0,8,8,0">
                        <DockPanel>
                            <!-- Zaglavlje chat-a -->
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,12">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#FF0000"
                                            CornerRadius="20"
                                            Width="40" Height="40"
                                            Margin="0,0,12,0">
                                        <TextBlock x:Name="txtChatAvatar"
                                                   Text=""
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="txtChatClientName"
                                                   Text="Odaberite razgovor"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFD"/>
                                        <TextBlock x:Name="txtChatStatus"
                                                   Text=""
                                                   FontSize="11"
                                                   Foreground="#7A7A7A"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Unos poruka -->
                            <Border DockPanel.Dock="Bottom"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="0,1,0,0"
                                    Padding="15,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="txtMessage"
                                             Grid.Column="0"
                                             Background="#1A1A1A"
                                             Foreground="#FFFFFD"
                                             BorderBrush="#2A2A2A"
                                             BorderThickness="1"
                                             Padding="12,10"
                                             FontSize="14"
                                             CaretBrush="#FFFFFD"
                                             AcceptsReturn="False"
                                             KeyDown="txtMessage_KeyDown"
                                             MaxLength="255">
                                        <TextBox.Template>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="5"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                </Border>
                                            </ControlTemplate>
                                        </TextBox.Template>
                                    </TextBox>

                                    <Button x:Name="btnSend"
                                            Grid.Column="1"
                                            Content="Pošalji"
                                            Background="#FF0000"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="20,10"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Margin="10,0,0,0"
                                            Click="btnSend_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#CC0000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Prikaz poruka -->
                            <TextBlock x:Name="txtNoMessages"
                                       FontSize="14"
                                       Foreground="#7A7A7A"
                                       Visibility="Collapsed"/>
                            <ScrollViewer x:Name="scrollMessages"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="wpConversation"
                                              Margin="15">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Border Background="#2D2D2D"
                                                        CornerRadius="12,12,12,0"
                                                        Padding="14,10"
                                                        MaxWidth="450"
                                                        HorizontalAlignment="Left"
                                                        Visibility="{Binding ReceivedVisibility}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Content}"
                                                                   FontSize="14"
                                                                   Foreground="#FFFFFD"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding SenderName}"
                                                                   FontSize="10"
                                                                   Foreground="#7A7A7A"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Background="#FF0000"
                                                        CornerRadius="12,12,0,12"
                                                        Padding="14,10"
                                                        MaxWidth="450"
                                                        HorizontalAlignment="Right"
                                                        Visibility="{Binding SentVisibility}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Content}"
                                                                   FontSize="14"
                                                                   Foreground="White"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="Ti"
                                                                   FontSize="10"
                                                                   Foreground="#FFCCCC"
                                                                   Margin="0,4,0,0"
                                                                   HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Obavijesti -->
            <TabItem Header="Obavijesti">
                <Border Background="#0D0D0D"
                        CornerRadius="8"
                        Margin="0,15,0,0"
                        Padding="20">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="Obavijesti"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#FFFFFD"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="btnRefreshNotifications"
                                    Content="Osvježi"
                                    Background="#2A2A2A"
                                    Foreground="#FFFFFD"
                                    BorderThickness="0"
                                    Padding="15,8"
                                    Margin="20,0,0,0"
                                    FontSize="12"
                                    Cursor="Hand"
                                    Click="btnRefreshNotifications_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="txtNoNotifications"
                                   Text="Nema novih obavijesti."
                                   FontSize="14"
                                   Foreground="#7A7A7A"
                                   Visibility="Collapsed"/>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icNotifications">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1A1A1A"
                                                CornerRadius="6"
                                                Padding="15"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSeen, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,15,0"
                                                          Checked="NotificationCheckBox_Changed"
                                                          Unchecked="NotificationCheckBox_Changed"
                                                          Tag="{Binding}"/>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#FFFFFD"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="#7A7A7A"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- Povratne informacije -->
            <TabItem Header="Povratne informacije" x:Name="tabFeedback">
                <ContentControl x:Name="feedbackContent"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
