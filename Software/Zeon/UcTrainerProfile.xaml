<UserControl x:Class="Zeon.UcTrainerProfile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0A0A0A">

    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="5,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="CaretBrush" Value="#FFFFFD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#1A0000"/>
            <Setter Property="Foreground" Value="#FF0000"/>
            <Setter Property="BorderBrush" Value="#5E0000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="ToggleStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Zaglavlje -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Profil"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#FFFFFD"
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock x:Name="txtHeaderName"
                           Text=""
                           FontSize="14"
                           Foreground="#FFFFFD"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>
                <Border Background="#FF0000"
                        CornerRadius="20"
                        Width="40"
                        Height="40">
                    <TextBlock x:Name="txtHeaderInitials"
                               Text=""
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Sadržaj -->
        <TabControl x:Name="tabProfile"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#7A7A7A"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="Padding" Value="15,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="tabBorder"
                                        Background="Transparent"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="0,0,10,0"
                                        Cursor="Hand">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder" Property="BorderBrush" Value="#FF0000"/>
                                        <Setter Property="Foreground" Value="#FFFFFD"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Moj profil -->
            <TabItem Header="Moj profil">
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,20,0,0">
                    <StackPanel>

                        <!-- Statistika trenera -->
                        <Border Style="{StaticResource SectionCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,30,0" HorizontalAlignment="Center">
                                    <Border Width="120" Height="120" CornerRadius="60" Margin="0,0,0,10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF0000" Offset="0"/>
                                                <GradientStop Color="#5E0000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock x:Name="txtAvatarInitials"
                                                   Text=""
                                                   FontSize="36"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Button Content="Promijeni sliku"
                                            Width="125"
                                            Style="{StaticResource DarkButton}"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Padding="12,6"/>
                                    <Button x:Name="btnLogout"
                                            Content="Odjava"
                                            Width="125"
                                            Style="{StaticResource DangerButton}"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Padding="16,8"
                                            Margin="0,10,0,0"
                                            Click="btnLogout_Click"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtProfileName"
                                               Text=""
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="#FFFFFD"
                                               Margin="0,0,0,5"/>
                                    <TextBlock x:Name="txtProfileTitle"
                                               Text="Osobni trener"
                                               FontSize="14"
                                               Foreground="#9A9A9A"
                                               Margin="0,0,0,20"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Klijenti" FontSize="12" Foreground="#7A7A7A" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtStatClients" Text="0" FontSize="22" FontWeight="Bold" Foreground="#FF0000"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Iskustvo" FontSize="12" Foreground="#7A7A7A" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtStatExperience" Text="-" FontSize="22" FontWeight="Bold" Foreground="#FFFFFD"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Ocjena" FontSize="12" Foreground="#7A7A7A" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtStatRating" Text="-" FontSize="22" FontWeight="Bold" Foreground="#FFFFFD"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="Cijena" FontSize="12" Foreground="#7A7A7A" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="txtStatPrice" Text="-" FontSize="22" FontWeight="Bold" Foreground="#FFFFFD"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Osobni podaci -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Osobni podaci" Style="{StaticResource SectionTitle}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Column="0" Grid.Row="0">
                                        <TextBlock Text="Ime i prezime" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtNameSurname" Style="{StaticResource InputField}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Grid.Row="0">
                                        <TextBlock Text="E-mail" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtEmail" Style="{StaticResource InputField}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="1">
                                        <TextBlock Text="Korisnicko ime" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtUsername" Style="{StaticResource InputField}" IsReadOnly="True" Foreground="#999999"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Grid.Row="1">
                                        <TextBlock Text="Datum zaposlenja" Style="{StaticResource FieldLabel}"/>
                                        <DatePicker x:Name="dpEmploymentDate"
                                                    Background="#1A1A1A"
                                                    Foreground="#212121"
                                                    BorderBrush="#2A2A2A"
                                                    BorderThickness="1"
                                                    Padding="12,10"
                                                    FontSize="14"
                                                    Margin="0,0,0,15"
                                                    />
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Cijena (EUR)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtPrice" Style="{StaticResource InputField}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Godine iskustva" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="txtExperience" IsReadOnly="True" Foreground="#505050" Style="{StaticResource InputField}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Opis / Bio" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtDescription"
                                         Style="{StaticResource InputField}"
                                         Height="100"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    <Button Content="Odustani"
                                            Style="{StaticResource DarkButton}"
                                            Click="btnCancelPersonal_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Specijalizacija -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Specijalizacija" Style="{StaticResource SectionTitle}"/>

                                <StackPanel>
                                    <TextBlock Text="Specijalizacija" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox x:Name="cmbPrimarySpec" Style="{StaticResource ComboStyle}" Foreground="#212121">
                                        <ComboBoxItem Content="Mišićna masa"/>
                                        <ComboBoxItem Content="Gubitak masti"/>
                                        <ComboBoxItem Content="Funkcionalni trening"/>
                                        <ComboBoxItem Content="Kardio"/>
                                        <ComboBoxItem Content="Rehabilitacija"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                    <Button Content="Odustani"
                                            Style="{StaticResource DarkButton}"
                                            Click="btnCancelPersonal_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Promjena lozinke -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Promjena lozinke" Style="{StaticResource SectionTitle}"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Stara lozinka" Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="txtOldPassword"
                                                     Background="#1A1A1A"
                                                     Foreground="#FFFFFD"
                                                     BorderBrush="#2A2A2A"
                                                     BorderThickness="1"
                                                     Padding="12,10"
                                                     FontSize="14" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Nova lozinka" Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="txtNewPassword"
                                                     Background="#1A1A1A"
                                                     Foreground="#FFFFFD"
                                                     BorderBrush="#2A2A2A"
                                                     BorderThickness="1"
                                                     Padding="12,10"
                                                     FontSize="14"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Potvrdi novu lozinku" Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="txtConfirmPassword"
                                                     Background="#1A1A1A"
                                                     Foreground="#FFFFFD"
                                                     BorderBrush="#2A2A2A"
                                                     BorderThickness="1"
                                                     Padding="12,10"
                                                     FontSize="14"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                                    <Button Content="Odustani"
                                            Style="{StaticResource DarkButton}"
                                            Margin="0,0,10,0"
                                            Click="btnCancelPassword_Click"/>
                                    <Button x:Name="btnChangePassword"
                                            Content="Promijeni lozinku"
                                            Style="{StaticResource RedButton}"
                                            Click="btnChangePassword_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Spremi promjene -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,20,20">
                            <Button x:Name="btnSaveAll"
                                    HorizontalAlignment="Center"
                                    Content="Spremi promjene"
                                    Style="{StaticResource RedButton}"
                                    Click="btnSavePersonal_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
