<UserControl x:Class="Zeon.Recipes"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Zeon"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#0A0A0A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Zaglavlje -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Prehrana"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#FFFFFD"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Tabovi -->
        <TabControl x:Name="tabNutrition"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#7A7A7A"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="Padding" Value="15,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="tabBorder"
                                        Background="Transparent"
                                        BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="0,0,10,0"
                                        Cursor="Hand">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder" Property="BorderBrush" Value="#FF0000"/>
                                        <Setter Property="Foreground" Value="#FFFFFD"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Upravljanje namirnicama -->
            <TabItem Header="Baza hrane" x:Name="tabFoodManage">
                <ContentControl x:Name="foodManageContent" Margin="0,15,0,0"/>
            </TabItem>

            <!-- Planovi prehrane -->
            <TabItem Header="Planovi prehrane" x:Name="tabFoodPlans">
                <ContentControl x:Name="foodPlansContent" Margin="0,15,0,0"/>
            </TabItem>

            <!-- Recepti -->
            <TabItem Header="Recepti" x:Name="tabRecipes">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#0D0D0D"
                            CornerRadius="8"
                            Padding="20">

                        <DataGrid x:Name="dgRecipes"
                                  AutoGenerateColumns="False"
                                  MouseDoubleClick="DgRecipes_MouseDoubleClick"
                                  Background="Transparent"
                                  Foreground="#FFFFFD"
                                  BorderThickness="0"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  FontSize="14"
                                  RowHeight="50">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#7A7A7A"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="10,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                            <Setter Property="Foreground" Value="#FF0000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#141414"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding id_recipe}" Width="60"/>
                                <DataGridTextColumn Header="NAZIV RECEPTA" Binding="{Binding recipe_name}" Width="2*"/>
                                <DataGridTextColumn Header="OPIS" Binding="{Binding recipe_description}" Width="3*"/>
                                <DataGridTextColumn Header="UKUPNO KCAL" Binding="{Binding TotalKcal, StringFormat={}{0:N0} kcal}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

                        <Button x:Name="btnNew" Content="+ Novi recept" Click="BtnNew_Click"
                                Width="140" Height="45" Background="#FF0000" Foreground="White"
                                FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnEdit" Content="Uredi" Click="BtnEdit_Click"
                                Width="110" Height="45" Background="#1A1A1A" Foreground="#FFFFFD"
                                FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#3A3A3A" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnDelete" Content="Izbriši" Click="BtnDelete_Click"
                                Width="110" Height="45" Background="#1A1A1A" Foreground="#FF4444"
                                FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#3A3A3A" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
