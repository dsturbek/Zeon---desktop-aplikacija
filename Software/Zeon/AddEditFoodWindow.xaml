<Window x:Class="Zeon.AddEditFoodWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zeon"
        mc:Ignorable="d"
        Height="700" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Name="txtTitle"
                   Grid.Row="0"
                   Text="Dodaj hranu" 
                   FontSize="28" 
                   FontWeight="Bold"
                   Foreground="#FFFFFD"/>

        <ScrollViewer Grid.Row="2" 
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="OSNOVNE INFORMACIJE" 
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   Margin="0,0,0,20"/>

                        <Label Content="Naziv hrane:" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <TextBox Name="txtFoodName"
                                 Height="45"
                                 Padding="15,0"
                                 FontSize="14"
                                 Background="#2A2A2A"
                                 Foreground="#FFFFFD"
                                 BorderBrush="#3A3A3A"
                                 BorderThickness="1"
                                 Margin="0,0,0,15"/>

                        <Label Content="Kalorije (kcal) na 100g:" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <TextBox Name="txtCalories"
                                 Height="45"
                                 Padding="15,0"
                                 FontSize="14"
                                 Background="#2A2A2A"
                                 Foreground="#FFFFFD"
                                 BorderBrush="#3A3A3A"
                                 BorderThickness="1"
                                 Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#1A1A1A"
                        CornerRadius="8"
                        Padding="25"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="MAKRONUTRIJENTI (na 100g)" 
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#7A7A7A"
                                   Margin="0,0,0,20"/>

                        <Label Content="Proteini (g):" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <Border Background="#2A2A2A"
                                BorderBrush="#FF0000"
                                BorderThickness="0,0,0,3"
                                CornerRadius="5"
                                Margin="0,0,0,15">
                            <TextBox Name="txtProteins"
                                     Height="45"
                                     Padding="15,0"
                                     FontSize="14"
                                     Background="Transparent"
                                     Foreground="#FFFFFD"
                                     BorderThickness="0"/>
                        </Border>

                        <Label Content="Ugljikohidrati (g):" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <Border Background="#2A2A2A"
                                BorderBrush="#0066FF"
                                BorderThickness="0,0,0,3"
                                CornerRadius="5"
                                Margin="0,0,0,15">
                            <TextBox Name="txtCarbohydrates"
                                     Height="45"
                                     Padding="15,0"
                                     FontSize="14"
                                     Background="Transparent"
                                     Foreground="#FFFFFD"
                                     BorderThickness="0"/>
                        </Border>

                        <Label Content="Masti (g):" 
                               Foreground="#FFFFFD"
                               FontSize="14"
                               Margin="0,0,0,5"/>
                        <Border Background="#2A2A2A"
                                BorderBrush="#FFB800"
                                BorderThickness="0,0,0,3"
                                CornerRadius="5"
                                Margin="0,0,0,0">
                            <TextBox Name="txtFat"
                                     Height="45"
                                     Padding="15,0"
                                     FontSize="14"
                                     Background="Transparent"
                                     Foreground="#FFFFFD"
                                     BorderThickness="0"/>
                        </Border>

                        <TextBlock Text="💡 Makronutrijenti se odnose na 100g proizvoda."
                                   FontSize="12"
                                   Foreground="#7A7A7A"
                                   TextWrapping="Wrap"
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Name="btnCancel"
                    Content="Odustani"
                    Height="50"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="#2A2A2A"
                    Foreground="#FFFFFD"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnCancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    Name="btnDelete"
                    Content="Obriši"
                    Height="50"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="Transparent"
                    Foreground="#FF0000"
                    BorderBrush="#FF0000"
                    BorderThickness="2"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Click="btnDelete_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF0000"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="4"
                    Name="btnSave"
                    Content="Spremi"
                    Height="50"
                    Width="150"
                    FontSize="15"
                    FontWeight="Bold"
                    Background="#FF0000"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnSave_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
