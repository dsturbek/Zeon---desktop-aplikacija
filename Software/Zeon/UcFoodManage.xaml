<UserControl x:Class="Zeon.UcFoodManage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Zeon"
             mc:Ignorable="d"
             Background="#0A0A0A"
             Loaded="UserControl_Loaded">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="3" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
            Background="#1A1A1A"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="5"
            Padding="15,0">
                <Grid>
                    <TextBox Name="txtSearch"
                     Background="Transparent"
                     Foreground="#FFFFFD"
                     BorderThickness="0"
                     FontSize="14"
                     VerticalAlignment="Center"
                     TextChanged="txtSearch_TextChanged"
                     GotFocus="txtSearch_GotFocus"
                     LostFocus="txtSearch_LostFocus"/>

                    <TextBlock Name="txtSearchPlaceholder"
                       Text="Pretraži hranu..."
                       FontSize="14"
                       Foreground="#7A7A7A"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       Visibility="Visible"/>
                </Grid>
            </Border>

            <Button Grid.Column="2"
            Name="btnAddFood"
            Content="+ Dodaj hranu"
            Height="40"
            Padding="25,0"
            Background="#FF0000"
            Foreground="White"
            FontSize="14"
            FontWeight="Bold"
            BorderThickness="0"
            Cursor="Hand"
            Click="btnAddFood_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC0000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="5" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Name="spFoodCards"/>
        </ScrollViewer>
    </Grid>
</UserControl>
