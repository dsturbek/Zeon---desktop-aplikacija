<Window x:Class="Zeon.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zeon"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Height="450" Width="800"
        WindowState="Maximized"
        Background="#141414">
    <Grid>
        <Border Width="450" Height="350" 
                Background="Transparent" 
                CornerRadius="5"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="30">

            <StackPanel>
                <TextBlock Text="Prijava Trenera" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="#FFFFFD"
                           Background="Transparent"
                           Margin="0,0,0,10"/>

                <Label Content="Korisničko ime" Foreground="#FFFFFD"/>
                <TextBox Name="txtUsername" 
                         Height="30" 
                         Padding="5"
                         Margin="0,0,0,10"/>

                <Label Content="Lozinka" Foreground="#FFFFFD"/>
                <PasswordBox Name="txtPassword" 
                             Height="30" 
                             Padding="5"
                             Margin="0,0,0,20"/>

                <Button Name="btnLogin" 
                        Content="Prijava" 
                        Height="40"
                        Background="#FF0000"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,15"
                        Click="btnLogin_Click"/>

                

                <TextBlock HorizontalAlignment="Right">
                    <Hyperlink Name="lnkRegister" 
                               Click="lnkRegister_Click"
                               Foreground="#5E5E5E">
                        Nemate račun? Registrirajte se!
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
