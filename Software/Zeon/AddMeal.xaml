<UserControl x:Class="Zeon.AddMeal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="#0A0A0A">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="InputField" TargetType="Control">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="RedButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0000"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CC0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#FFFFFD"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                <Button x:Name="btnBack" Content="←" Style="{StaticResource DarkButton}" 
                        Width="40" Height="40" FontSize="18" Click="BtnBack_Click" Margin="0,0,20,0"/>
                <TextBlock Text="Novi Obrok" FontSize="28" FontWeight="Bold" Foreground="#FFFFFD" VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,20">
                <Border Background="#121212" CornerRadius="8" Padding="20" Margin="0,0,10,0" BorderBrush="#222222" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="TIP OBROKA" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbMealType" Height="40" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Doručak" IsSelected="True"/>
                            <ComboBoxItem Content="Ručak"/>
                            <ComboBoxItem Content="Večera"/>
                            <ComboBoxItem Content="Užina"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="#121212" CornerRadius="8" Padding="20" Margin="10,0,0,0" BorderBrush="#222222" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="DATUM" Style="{StaticResource FieldLabel}"/>
                        <DatePicker x:Name="dtpMealDate" Height="40" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Background="#121212" CornerRadius="8" Padding="25" BorderBrush="#222222" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="DODAVANJE NAMIRNICA" Style="{StaticResource FieldLabel}" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Pretraži bazu" Style="{StaticResource FieldLabel}" FontSize="11"/>
                            <TextBox x:Name="txtSearchFood" Height="40" VerticalContentAlignment="Center" 
                                     TextChanged="TxtSearchFood_TextChanged" Tag="Npr. Piletina..."/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Količina (g)" Style="{StaticResource FieldLabel}" FontSize="11"/>
                            <TextBox x:Name="txtAmount" Height="40" Text="100" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <Button x:Name="btnAddFood" Grid.Column="2" Content="DODAJ" Height="40" 
                                Style="{StaticResource RedButton}" VerticalAlignment="Bottom" Click="BtnAddFood_Click"/>
                    </Grid>

                    <Popup x:Name="popResults" IsOpen="False" PlacementTarget="{Binding ElementName=txtSearchFood}" StaysOpen="False">
                        <Border Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1" Width="{Binding ElementName=txtSearchFood, Path=ActualWidth}">
                            <ListBox x:Name="lstSearchResults" Background="Transparent" BorderThickness="0" MaxHeight="250"
                                     SelectionChanged="LstSearchResults_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Foreground="#2196F3" FontWeight="Bold" Margin="0,0,5,0" />
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
                                                </StackPanel>
                                                <TextBlock Foreground="#9A9A9A" FontSize="12">
                                                    <Run Text="{Binding Kcal, StringFormat=\{0:N1\}}"/>
                                                    <Run Text=" kcal"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{Binding Type}"/>            
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>

                    <DataGrid x:Name="dgAddedFoods" Grid.Row="2" AutoGenerateColumns="False" MinHeight="250"
                              Background="#141414" Foreground="White" BorderThickness="0" 
                              CanUserAddRows="False" IsReadOnly="True" RowHeight="50" 
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#222222"
                              HeadersVisibility="Column" SelectionMode="Single">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#141414"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,0,10,10"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#222222"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#141414"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A1A1A"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#222222"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <Border Padding="10,0" Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAMIRNICA" Binding="{Binding Food.name}" Width="*"/>
                            <DataGridTextColumn Header="KOLIČINA" Binding="{Binding amount, StringFormat=\{0\}g}" Width="100"/>
                            <DataGridTextColumn Header="KALORIJE" Binding="{Binding TotalKcal, StringFormat=\{0:N1\} kcal}" Width="120"/>

                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Ukloni" 
                            Click="BtnRemoveFood_Click"
                            Foreground="#FF4444"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="11" 
                            Cursor="Hand"
                            HorizontalAlignment="Right"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="Odustani" Style="{StaticResource DarkButton}" Width="120" Height="45" Margin="0,0,15,0" Click="BtnBack_Click"/>
                <Button x:Name="btnSave" Content="SPREMI OBROK" Style="{StaticResource RedButton}" Width="160" Height="45" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>